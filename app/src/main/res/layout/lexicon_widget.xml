<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <TextView
        android:id="@+id/w_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TAHSIN\'S LEXICON"
        android:textColor="#FFE8C547"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/w_due"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="0 cards due"
        android:textColor="#FFEDF1FB"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/w_band"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Band —"
        android:textColor="#FF7FC29B"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/w_streak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0-day streak"
        android:textColor="#FF9FB2D8"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/w_wotd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Word: —"
        android:textColor="#FF9FB2D8"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
